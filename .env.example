# ── SimAPI configuration ────────────────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit a real `.env`. All values are optional
# in development; production deployments should set auth + secrets explicitly.

# Service
SIMAPI_ENV=development            # development | staging | production
SIMAPI_HOST=0.0.0.0
SIMAPI_PORT=8000
SIMAPI_LOG_LEVEL=INFO
SIMAPI_LOG_JSON=true              # structured JSON logs (recommended in prod)

# Authentication (comma-separated keys). Leave empty to disable auth in dev.
SIMAPI_API_KEYS=
SIMAPI_REQUIRE_AUTH=false

# Rate limiting (token bucket, per caller)
SIMAPI_RATE_LIMIT_ENABLED=true
SIMAPI_RATE_LIMIT_RPM=120
SIMAPI_RATE_LIMIT_BURST=20

# CORS (comma-separated origins; "*" allows all — tighten in prod)
SIMAPI_CORS_ORIGINS=*

# Job store retention
SIMAPI_JOB_TTL_SECONDS=3600
SIMAPI_MAX_JOBS=10000

# Payload limits
SIMAPI_MAX_ROWS=1000000
SIMAPI_MAX_UPLOAD_BYTES=104857600

# AI reasoning layer (optional). Without a key the AI layer reports "disabled"
# and physics validation runs unaffected.
SIMAPI_OPENROUTER_API_KEY=
SIMAPI_AI_MODEL=anthropic/claude-3.5-haiku
SIMAPI_AI_TIMEOUT_SECONDS=30

# SDK (client-side)
SIMAPI_BASE_URL=http://localhost:8000
SIMAPI_API_KEY=
